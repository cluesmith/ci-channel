{
  "name": "ci-channel",
  "version": "0.1.0",
  "description": "Claude Code channel plugin for real-time GitHub Actions CI/CD failure notifications",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cluesmith/ci-channel.git"
  },
  "keywords": [
    "claude-code",
    "mcp",
    "github-actions",
    "ci",
    "notifications",
    "channel-plugin"
  ],
  "scripts": {
    "start": "node --import tsx/esm server.ts",
    "build": "echo 'No build step — tsx runs TypeScript directly'",
    "test": "node --import tsx/esm --test --test-force-exit tests/*.test.ts tests/forges/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "smee-client": "^2.0.4",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
